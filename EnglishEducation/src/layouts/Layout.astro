---
import Navbar from '../components/Navbar.astro';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Fun English lessons, word games, and grammar quizzes for kids." } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Kids English Academy</title>
		<meta name="description" content={description} />
		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Kantumruy+Pro:wght@400;500;600;700&family=Outfit:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
		
		<!-- Inline Blocking Script to Prevent FOUT of Language -->
		<script is:inline>
			(function() {
				const savedLang = localStorage.getItem('preferredLang');
				if (savedLang === 'khmer') {
					document.documentElement.classList.add('lang-khmer');
				}
			})();
		</script>
	</head>
	<body>
		<!-- Fun Pastel Backdrop -->
		<div class="pastel-container">
			<div class="pastel-orb orb-yellow"></div>
			<div class="pastel-orb orb-pink"></div>
			<div class="pastel-orb orb-blue"></div>
		</div>

		<Navbar />

		<main class="main-content">
			<slot />
		</main>

		<footer class="footer">
			<div class="footer-content">
				<p class="footer-tagline">
					<span class="en-text-block">🎈 learning is an adventure! 🎈</span>
					<span class="kh-text-block">🎈 ការសិក្សាគឺជាការផ្សងព្រេង! 🎈</span>
				</p>
				<p>
					<span class="en-text">&copy; {new Date().getFullYear()} Kids English Academy. Designed for elementary learners.</span>
					<span class="kh-text">&copy; {new Date().getFullYear()} វិទ្យាស្ថានភាសាអង់គ្លេសកុមារ។ រចនាឡើងសម្រាប់សិស្សបឋមសិក្សា។</span>
				</p>
			</div>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		--font-sans: 'Inter', system-ui, -apple-system, sans-serif;
		--font-display: 'Outfit', var(--font-sans);

		/* Colors - Playful Light Pastel Palette */
		--bg-light: #faf9f6;
		--bg-surface: #ffffff;
		--bg-surface-hover: #fdfcfa;
		--border-color: rgba(226, 232, 240, 0.8);
		--border-glow: rgba(167, 139, 250, 0.4);
		
		--color-text: #2d3748;
		--color-text-muted: #718096;
		
		/* Playful pastel accents */
		--color-primary: #9f7aea; /* Gentle Purple */
		--color-secondary: #06b6d4; /* Soft Cyan */
		--color-accent: #fb7185; /* Warm Rose */
		--color-success: #34d399; /* Mint Green */
		--color-warning: #fbbf24; /* Sunny Yellow */

		--glass-blur: 12px;
		--radius-lg: 24px;
		--radius-md: 16px;
		--radius-sm: 10px;
		--transition-smooth: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
		--shadow-playful: 0 10px 25px -5px rgba(159, 122, 234, 0.1), 0 8px 10px -6px rgba(159, 122, 234, 0.05);
	}

	/* ==========================================
	   Bilingual Text Display Logic
	   ========================================== */
	html.lang-khmer {
		font-family: 'Kantumruy Pro', var(--font-sans);
	}

	.kh-text {
		display: none !important;
	}
	.en-text {
		display: inline !important;
	}
	html.lang-khmer .kh-text {
		display: inline !important;
	}
	html.lang-khmer .en-text {
		display: none !important;
	}

	.kh-text-block {
		display: none !important;
	}
	.en-text-block {
		display: block !important;
	}
	html.lang-khmer .kh-text-block {
		display: block !important;
	}
	html.lang-khmer .en-text-block {
		display: none !important;
	}

	.kh-text-flex {
		display: none !important;
	}
	.en-text-flex {
		display: flex !important;
	}
	html.lang-khmer .kh-text-flex {
		display: flex !important;
	}
	html.lang-khmer .en-text-flex {
		display: none !important;
	}

	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	html {
		font-family: var(--font-sans);
		background-color: var(--bg-light);
		color: var(--color-text);
		scroll-behavior: smooth;
		overflow-x: hidden;
	}

	body {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		position: relative;
		line-height: 1.6;
	}

	/* Soft Pastel Glows */
	.pastel-container {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		pointer-events: none;
		z-index: -1;
		overflow: hidden;
		background: linear-gradient(135deg, #fefeff 0%, #f7f9fc 100%);
	}

	.pastel-orb {
		position: absolute;
		border-radius: 50%;
		filter: blur(100px);
		opacity: 0.4;
	}

	.orb-yellow {
		top: -10%;
		left: 20%;
		width: 40vw;
		height: 40vw;
		background: #fef08a;
	}

	.orb-pink {
		bottom: 10%;
		right: -5%;
		width: 45vw;
		height: 45vw;
		background: #fecdd3;
	}

	.orb-blue {
		bottom: -10%;
		left: -5%;
		width: 35vw;
		height: 35vw;
		background: #bae6fd;
	}

	/* Main Content Layout */
	.main-content {
		flex: 1;
		width: 100%;
		max-width: 1100px;
		margin: 0 auto;
		padding: 90px 24px 40px 24px;
		animation: bounceIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
	}

	/* Playful workbook-style cards */
	.glass-card {
		background: var(--bg-surface);
		border: 3px solid #e2e8f0;
		border-radius: var(--radius-lg);
		padding: 32px;
		transition: var(--transition-smooth);
		box-shadow: var(--shadow-playful);
		position: relative;
	}

	.glass-card::after {
		content: '';
		position: absolute;
		z-index: -1;
		top: 3px;
		left: 3px;
		right: -3px;
		bottom: -3px;
		background: #cbd5e1;
		border-radius: var(--radius-lg);
		transition: var(--transition-smooth);
	}

	.glass-card:hover {
		transform: translate(-2px, -2px);
		border-color: #cbd5e1;
	}

	.glass-card:hover::after {
		top: 6px;
		left: 6px;
		right: -6px;
		bottom: -6px;
		background: rgba(167, 139, 250, 0.2);
	}

	/* Typography helper */
	h1, h2, h3, h4 {
		font-family: var(--font-display);
		color: #1a202c;
		font-weight: 800;
	}

	h1 {
		font-size: 2.8rem;
		line-height: 1.2;
		color: #2d3748;
	}

	/* Playful Buttons styling */
	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		padding: 14px 28px;
		font-family: var(--font-display);
		font-size: 1.1rem;
		font-weight: 800;
		border-radius: var(--radius-md);
		border: 3px solid #000000;
		cursor: pointer;
		transition: var(--transition-smooth);
		text-decoration: none;
		position: relative;
	}

	.btn-primary {
		background: #fef08a;
		color: #1a202c;
		box-shadow: 0 4px 0 #000000;
	}

	.btn-primary:hover {
		background: #fde047;
		transform: translateY(-2px);
		box-shadow: 0 6px 0 #000000;
	}

	.btn-primary:active {
		transform: translateY(2px);
		box-shadow: 0 2px 0 #000000;
	}

	.btn-secondary {
		background: #ffffff;
		color: #1a202c;
		box-shadow: 0 4px 0 #000000;
	}

	.btn-secondary:hover {
		background: #f8fafc;
		transform: translateY(-2px);
		box-shadow: 0 6px 0 #000000;
		border-color: #000000;
	}

	.btn-secondary:active {
		transform: translateY(2px);
		box-shadow: 0 2px 0 #000000;
	}

	/* Footer styling */
	.footer {
		border-top: 3px solid #e2e8f0;
		background: #ffffff;
		padding: 24px;
		margin-top: auto;
		text-align: center;
	}

	.footer-content {
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	.footer-tagline {
		font-family: var(--font-display);
		font-size: 1.1rem;
		font-weight: 800;
		text-transform: uppercase;
		color: var(--color-primary);
		letter-spacing: 0.5px;
	}

	.footer p {
		color: var(--color-text-muted);
		font-size: 0.85rem;
		font-weight: 500;
	}

	@keyframes bounceIn {
		0% {
			opacity: 0;
			transform: scale(0.95) translateY(10px);
		}
		70% {
			transform: scale(1.02) translateY(-2px);
		}
		100% {
			opacity: 1;
			transform: scale(1) translateY(0);
		}
	}

	@media (max-width: 768px) {
		h1 {
			font-size: 2.2rem;
		}
		.main-content {
			padding: 90px 16px 30px 16px;
		}
	}
</style>
