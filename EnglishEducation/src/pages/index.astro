---
import Layout from '../layouts/Layout.astro';
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<Layout title="Fun English Learning for Kids" description="Interactive word games, reading cards, and fun quizzes for kids from 1st to 4th grade, localized for Cambodian learners.">
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="hero-content">
      <h1 class="hero-title">
        <span class="en-text-block">Learn English with <br/><span class="text-glow">Fun Games! рҹҺҲ</span></span>
        <span class="kh-text-block">бһҡбҹҖбһ“бһ—бһ¶бһҹбһ¶бһўбһ„бҹӢбһӮбҹ’бһӣбҹҒбһҹбһҮбһ¶бһҳбһҪбһҷ <br/><span class="text-glow">бһӣбҹ’бһ”бҹӮбһ„бһҖбһҳбҹ’бһҹбһ¶бһ“бҹ’бһҸбһҹбһ”бҹ’бһ”бһ¶бһҷбҹ—! рҹҺҲ</span></span>
      </h1>
      
      <p class="hero-subtitle">
        <span class="en-text-block">Welcome to Kids English Academy! Explore our fun word cards, play cool grammar quizzes, and practice listening to happy stories. Let's start our learning adventure today! рҹҢҹ</span>
        <span class="kh-text-block">бһҹбһјбһҳбһҹбҹ’бһңбһ¶бһӮбһҳбһ“бҹҚбһҳбһҖбһҖбһ¶бһ“бҹӢбһңбһ·бһ‘бҹ’бһҷбһ¶бһҹбҹ’бһҗбһ¶бһ“бһ—бһ¶бһҹбһ¶бһўбһ„бҹӢбһӮбҹ’бһӣбҹҒбһҹбһҖбһ»бһҳбһ¶бһҡ! бһҹбҹ’бһңбҹӮбһ„бһҷбһӣбҹӢбһ–бһёбһҖбһ¶бһҸбһ–бһ¶бһҖбҹ’бһҷбһҹбһ·бһҖбҹ’бһҹбһ¶бһҠбҹҸбһҡбһёбһҖбһҡбһ¶бһҷ бһӣбҹҒбһ„бһӣбҹ’бһ”бҹӮбһ„бһҸбҹҒбһҹбҹ’бһҸбһҹбһ¶бһҖбһӣбҹ’бһ”бһ„бһңбҹҒбһҷбҹ’бһҷбһ¶бһҖбһҡбһҺбҹҚ бһ“бһ·бһ„бһ бҹ’бһңбһ№бһҖбһ бһ¶бһҸбҹӢбһҹбҹ’бһҸбһ¶бһ”бҹӢбһҡбһҝбһ„бһҡбҹүбһ¶бһңбһӮбһҪбһҡбһұбҹ’бһҷбһҹбҹ’бһҡбһЎбһ¶бһүбҹӢбҹ” бһҸбҹ„бҹҮбһ…бһ¶бһ”бҹӢбһ•бҹ’бһҸбһҫбһҳбһҖбһ¶бһҡбһ•бҹ’бһҹбһ„бһ–бҹ’бһҡбҹҒбһ„бһҗбҹ’бһ„бҹғбһ“бҹҒбҹҮ! рҹҢҹ</span>
      </p>
      
      <div class="hero-actions">
        <a href={`${baseUrl}vocabulary`} class="btn btn-primary">
          <span class="en-text">Start Learning! рҹҡҖ</span>
          <span class="kh-text">бһ…бһ¶бһ”бҹӢбһ•бҹ’бһҸбһҫбһҳбһҡбҹҖбһ“! рҹҡҖ</span>
        </a>
        <a href="#paths" class="btn btn-secondary">
          <span class="en-text">See Games рҹҺ®</span>
          <span class="kh-text">бһҳбһҫбһӣбһӣбҹ’бһ”бҹӮбһ„бһҖбһҳбҹ’бһҹбһ¶бһ“бҹ’бһҸ рҹҺ®</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Grade Level Selector Section -->
  <section class="grade-selection-section glass-card">
    <h2 class="grade-section-title">
      <span class="en-text">Select Your School Grade рҹҢҹ</span>
      <span class="kh-text">бһҮбҹ’бһҡбһҫбһҹбһҡбһҫбһҹбһҗбҹ’бһ“бһ¶бһҖбҹӢбһҡбҹҖбһ“бһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖ рҹҢҹ</span>
    </h2>
    <p class="grade-section-subtitle">
      <span class="en-text">Pick your grade below. The lessons and quizzes will automatically open at your level!</span>
      <span class="kh-text">бһҮбҹ’бһҡбһҫбһҹбһҡбһҫбһҹбһҗбҹ’бһ“бһ¶бһҖбҹӢбһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖбһҒбһ¶бһ„бһҖбҹ’бһҡбҹ„бһҳбҹ” бһҳбҹҒбһҡбҹҖбһ“ бһ“бһ·бһ„бһҸбҹҒбһҹбҹ’бһҸбһҹбһ¶бһҖбһӣбҹ’бһ”бһ„бһ‘бһ¶бҹҶбһ„бһўбһҹбҹӢбһ“бһ№бһ„бһ”бһ„бҹ’бһ бһ¶бһүбһҖбһҳбҹ’бһҡбһ·бһҸбһҠбҹӮбһӣбһҸбҹ’бһҡбһјбһңбһ“бһ№бһ„бһҗбҹ’бһ“бһ¶бһҖбҹӢбһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖбһҠбҹ„бһҷбһҹбҹ’бһңбҹҗбһҷбһ”бҹ’бһҡбһңбһҸбҹ’бһҸ!</span>
    </p>
    <div class="grade-bubbles">
      <button class="grade-bubble-btn" data-grade="grade3">
        <span class="bubble-title">
          <span class="en-text">Grade 3</span>
          <span class="kh-text">бһҗбҹ’бһ“бһ¶бһҖбҹӢбһ‘бһё бҹЈ</span>
        </span>
        <span class="bubble-sub">
          <span class="en-text">Level 1 English</span>
          <span class="kh-text">бһҖбһҳбҹ’бһҡбһ·бһҸ бҹЎ (бһ„бһ¶бһҷ)</span>
        </span>
      </button>
      
      <button class="grade-bubble-btn" data-grade="grade4">
        <span class="bubble-title">
          <span class="en-text">Grade 4</span>
          <span class="kh-text">бһҗбҹ’бһ“бһ¶бһҖбҹӢбһ‘бһё бҹӨ</span>
        </span>
        <span class="bubble-sub">
          <span class="en-text">Level 2 English</span>
          <span class="kh-text">бһҖбһҳбҹ’бһҡбһ·бһҸ бҹў (бһҳбһ’бҹ’бһҷбһҳ)</span>
        </span>
      </button>
      
      <button class="grade-bubble-btn" data-grade="grade5">
        <span class="bubble-title">
          <span class="en-text">Grade 5</span>
          <span class="kh-text">бһҗбҹ’бһ“бһ¶бһҖбҹӢбһ‘бһё бҹҘ</span>
        </span>
        <span class="bubble-sub">
          <span class="en-text">Level 3 English</span>
          <span class="kh-text">бһҖбһҳбҹ’бһҡбһ·бһҸ бҹЈ (бһ–бһ·бһ”бһ¶бһҖ)</span>
        </span>
      </button>
      
      <button class="grade-bubble-btn" data-grade="grade6">
        <span class="bubble-title">
          <span class="en-text">Grade 6</span>
          <span class="kh-text">бһҗбҹ’бһ“бһ¶бһҖбҹӢбһ‘бһё бҹҰ</span>
        </span>
        <span class="bubble-sub">
          <span class="en-text">Level 4 English</span>
          <span class="kh-text">бһҖбһҳбҹ’бһҡбһ·бһҸ бҹӨ (бһ–бһ·бһ”бһ¶бһҖбһҒбҹ’бһӣбһ¶бҹҶбһ„)</span>
        </span>
      </button>
    </div>
  </section>

  <!-- Learning Paths Section -->
  <section id="paths" class="paths-section">
    <h2 class="section-title">
      <span class="en-text">Pick Your Learning Game</span>
      <span class="kh-text">бһҮбҹ’бһҡбһҫбһҹбһҡбһҫбһҹбһӣбҹ’бһ”бҹӮбһ„бһҹбһ·бһҖбҹ’бһҹбһ¶бһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖ</span>
    </h2>
    <p class="section-subtitle">
      <span class="en-text">Choose one of the fun sections below to practice your English!</span>
      <span class="kh-text">бһҮбҹ’бһҡбһҫбһҹбһҡбһҫбһҹбһ•бҹ’бһ“бҹӮбһҖбһҠбҹҸбһҡбһёбһҖбһҡбһ¶бһҷбһҺбһ¶бһҳбһҪбһҷбһҒбһ¶бһ„бһҖбҹ’бһҡбҹ„бһҳ бһҠбһҫбһҳбҹ’бһ”бһёбһўбһ“бһ»бһңбһҸбҹ’бһҸбһ—бһ¶бһҹбһ¶бһўбһ„бҹӢбһӮбҹ’бһӣбҹҒбһҹбһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖ!</span>
    </p>
    
    <div class="paths-grid">
      <!-- Vocabulary Card -->
      <div class="path-card glass-card">
        <div class="card-icon-wrapper purple">
          <span>рҹҺЁ</span>
        </div>
        <h3 class="path-title">
          <span class="en-text">Fun Word Cards</span>
          <span class="kh-text">бһҖбһ¶бһҸбһ–бһ¶бһҖбҹ’бһҷбһҹбһ·бһҖбҹ’бһҹбһ¶</span>
        </h3>
        <p class="path-desc">
          <span class="en-text">Learn daily words with colorful cards! Tap the card to flip it and see what the word means. Click the speaker to hear how it sounds! рҹ”Ҡ</span>
          <span class="kh-text">бһҡбҹҖбһ“бһ–бһ¶бһҖбҹ’бһҷбһ”бҹ’бһҡбһ…бһ¶бҹҶбһҗбҹ’бһ„бҹғбһҮбһ¶бһҳбһҪбһҷбһҖбһ¶бһҸбһ…бһҳбҹ’бһҡбһ»бҹҮбһ–бһҺбҹҢ! бһ…бһ»бһ…бһӣбһҫбһҖбһ¶бһҸбһҠбһҫбһҳбҹ’бһ”бһёбһ•бҹ’бһ„бһ¶бһҡбһҳбһҫбһӣбһ“бҹҗбһҷбһ–бһ¶бһҖбҹ’бһҷбҹ” бһ…бһ»бһ…бһӣбһҫбһҡбһјбһ”бһ”бҹҶбһ–бһ„бһҹбҹҶбһЎбҹҒбһ„бһҠбһҫбһҳбҹ’бһ”бһёбһҹбҹ’бһҸбһ¶бһ”бҹӢбһҖбһ¶бһҡбһ”бһүбҹ’бһ…бҹҒбһүбһҹбҹҶбһЎбҹҒбһ„! рҹ”Ҡ</span>
        </p>
        <a href={`${baseUrl}vocabulary`} class="path-link">
          <span class="en-text">Play Word Cards &rarr;</span>
          <span class="kh-text">бһӣбҹҒбһ„бһҖбһ¶бһҸбһ–бһ¶бһҖбҹ’бһҷбһҹбһ·бһҖбҹ’бһҹбһ¶ &rarr;</span>
        </a>
      </div>

      <!-- Grammar Quiz Card -->
      <div class="path-card glass-card">
        <div class="card-icon-wrapper yellow">
          <span>вӯҗ</span>
        </div>
        <h3 class="path-title">
          <span class="en-text">Cool Quiz Games</span>
          <span class="kh-text">бһҸбҹҒбһҹбҹ’бһҸбһҹбһ¶бһҖбһӣбҹ’бһ”бһ„</span>
        </h3>
        <p class="path-desc">
          <span class="en-text">Answer questions and collect stars! Check your answers to see explanations that make grammar easy to learn! вңҸпёҸ</span>
          <span class="kh-text">бһҶбҹ’бһӣбһҫбһҷбһҹбҹҶбһҺбһҪбһҡбһ•бҹ’бһҹбҹҒбһ„бҹ— бһ“бһ·бһ„бһ”бҹ’бһҡбһҳбһјбһӣбһ•бҹ’бһҖбһ¶бһҷ! бһ–бһ·бһ“бһ·бһҸбҹ’бһҷбһҳбһҫбһӣбһ…бһҳбҹ’бһӣбһҫбһҷбһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖ бһҠбһҫбһҳбҹ’бһ”бһёбһҳбһҫбһӣбһҖбһ¶бһҡбһ–бһ“бҹ’бһҷбһӣбҹӢбһҠбҹӮбһӣбһҮбһҪбһҷбһұбҹ’бһҷбһңбҹҒбһҷбҹ’бһҷбһ¶бһҖбһҡбһҺбҹҚбһҖбһ¶бһ“бҹӢбһҸбҹӮбһ„бһ¶бһҷбһҷбһӣбҹӢ! вңҸпёҸ</span>
        </p>
        <a href={`${baseUrl}quiz`} class="path-link">
          <span class="en-text">Play Quiz Games &rarr;</span>
          <span class="kh-text">бһӣбҹҒбһ„бһҸбҹҒбһҹбҹ’бһҸбһҹбһ¶бһҖбһӣбҹ’бһ”бһ„ &rarr;</span>
        </a>
      </div>

      <!-- Listening Dictation Card -->
      <div class="path-card glass-card">
        <div class="card-icon-wrapper blue">
          <span>рҹҺ§</span>
        </div>
        <h3 class="path-title">
          <span class="en-text">Listen & Write</span>
          <span class="kh-text">бһҹбҹ’бһҸбһ¶бһ”бҹӢ бһ“бһ·бһ„бһҹбһҡбһҹбҹҒбһҡ</span>
        </h3>
        <p class="path-desc">
          <span class="en-text">Listen to sweet voice recordings! Choose slow or normal speed, type what you hear in the box, and find out if you got it right! рҹ“қ</span>
          <span class="kh-text">бһҹбҹ’бһҸбһ¶бһ”бҹӢбһҹбҹҶбһЎбҹҒбһ„бһўбһ¶бһ“бһҠбҹҸбһ–бһёбһҡбҹ„бҹҮ! бһҮбҹ’бһҡбһҫбһҹбһҡбһҫбһҹбһӣбҹ’бһ”бһҝбһ“бһҷбһәбһҸ бһ¬бһ’бһҳбҹ’бһҳбһҸбһ¶ бһңбһ¶бһҷбһ”бһүбҹ’бһ…бһјбһӣбһўбҹ’бһңбһёбһҠбҹӮбһӣбһўбҹ’бһ“бһҖбһ”бһ¶бһ“бһ®бһ“бҹ…бһҖбҹ’бһ“бһ»бһ„бһ”бҹ’бһҡбһўбһ”бҹӢ бһ бһҫбһҷбһ•бҹ’бһ‘бҹҖбһ„бһ•бҹ’бһ‘бһ¶бһҸбҹӢбһ…бһҳбҹ’бһӣбһҫбһҷбһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖ! рҹ“қ</span>
        </p>
        <a href={`${baseUrl}listening`} class="path-link">
          <span class="en-text">Practice Listening &rarr;</span>
          <span class="kh-text">бһ бҹ’бһңбһ№бһҖбһ бһ¶бһҸбҹӢбһҖбһ¶бһҡбһҹбҹ’бһҸбһ¶бһ”бҹӢ &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Interactive Features Spotlight -->
  <section class="features-spotlight glass-card">
    <div class="spotlight-content">
      <h2 class="spotlight-title">
        <span class="en-text">Voices Built Right In! рҹ—ЈпёҸ</span>
        <span class="kh-text">бһҳбһ¶бһ“бһҹбҹҶбһЎбҹҒбһ„бһўбһ¶бһ“бһҳбһҖбһҮбһ¶бһҳбһҪбһҷбһҹбҹ’бһҡбһ¶бһ”бҹӢ! рҹ—ЈпёҸ</span>
      </h2>
      <p class="spotlight-desc">
        <span class="en-text">Our game uses your web browser's friendly speaking voice to read words aloud. This means you don't have to wait for large audio files to download. You can practice as much as you like, anytime, anywhere!</span>
        <span class="kh-text">бһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһҹбһ·бһҖбҹ’бһҹбһ¶бһҡбһ”бһҹбҹӢбһҷбһҫбһ„бһ”бҹ’бһҡбһҫбһ”бҹ’бһҡбһ¶бһҹбҹӢбһ”бһ…бҹ’бһ…бҹҒбһҖбһңбһ·бһ‘бҹ’бһҷбһ¶бһ”бһүбҹ’бһ…бҹҒбһүбһҹбҹҶбһЎбҹҒбһ„бһҹбҹ’бһңбҹҗбһҷбһ”бҹ’бһҡбһңбһҸбҹ’бһҸбһ·бһ“бҹғбһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһҡбһ»бһҖбһҡбһҖбһңбһ·бһ”бһҹбһ¶бһҷбһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖ бһҠбһҫбһҳбҹ’бһ”бһёбһўбһ¶бһ“бһ–бһ¶бһҖбҹ’бһҷбһҒбҹ’бһӣбһ¶бҹҶбһ„бҹ—бҹ” бһ“бҹҒбҹҮбһҳбһ¶бһ“бһ“бҹҗбһҷбһҗбһ¶бһўбҹ’бһ“бһҖбһҳбһ·бһ“бһ…бһ¶бҹҶбһ”бһ¶бһ…бҹӢбһҡбһ„бҹӢбһ…бһ¶бҹҶбһ‘бһ¶бһүбһҷбһҖбһҜбһҖбһҹбһ¶бһҡбһҹбҹҶбһЎбҹҒбһ„бһ’бҹҶбҹ—бһ“бҹ„бҹҮбһ‘бҹҒбҹ” бһўбҹ’бһ“бһҖбһўбһ¶бһ…бһ бҹ’бһңбһ№бһҖбһ бһ¶бһҸбҹӢбһ”бһ¶бһ“бһ…бҹ’бһҡбһҫбһ“бһҸбһ¶бһҳбһ…бһ·бһҸбҹ’бһҸ бһ…бһ„бҹӢбһҡбҹҖбһ“бһ–бҹҒбһӣбһҺбһ¶бһҖбҹҸбһ”бһ¶бһ“ бһ‘бһёбһҺбһ¶бһҖбҹҸбһ”бһ¶бһ“!</span>
      </p>
      <div class="tech-tags">
        <span class="tech-tag">
          <span class="en-text">вӯҗ Kid-Friendly Design</span>
