<script>
  const gradeButtons = document.querySelectorAll('.grade-bubble-btn');
  
  // Read and apply saved grade preference
  const savedGrade = localStorage.getItem('preferredGrade') || 'grade3';
  const savedButton = document.querySelector(`.grade-bubble-btn[data-grade="${savedGrade}"]`);
  if (savedButton) {
    savedButton.classList.add('selected');
  }

  gradeButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      gradeButtons.forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      
      const grade = btn.getAttribute('data-grade');
      if (grade) {
        localStorage.setItem('preferredGrade', grade);
      }
    });
  });
</script>

