<Layout title="Bilingual Word Flashcards" description="Study English vocabulary words mapped by school grade. Mapped to 1st-4th grade English difficulty levels.">
  <div class="vocab-header">
    <h1 class="vocab-title">
      <span class="en-text">Fun Word Cards рҹ“Ү</span>
      <span class="kh-text">бһҖбһ¶бһҸбһ–бһ¶бһҖбҹ’бһҷбһҹбһ·бһҖбҹ’бһҹбһ¶бһҡбһёбһҖбһҡбһ¶бһҷ рҹ“Ү</span>
    </h1>
    <p class="vocab-subtitle">
      <span class="en-text">Study the words for your grade! You can change your grade on the home page.</span>
      <span class="kh-text">бһҹбһ·бһҖбҹ’бһҹбһ¶бһ–бһ¶бһҖбҹ’бһҷбһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһҗбҹ’бһ“бһ¶бһҖбҹӢбһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖ! бһўбҹ’бһ“бһҖбһўбһ¶бһ…бһ”бҹ’бһҸбһјбһҡбһҗбҹ’бһ“бһ¶бһҖбҹӢбһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖбһ“бҹ…бһӣбһҫбһ‘бҹҶбһ–бҹҗбһҡбһҠбһҫбһҳбҹ”</span>
    </p>
  </div>

  <!-- Grade 3 Tab Panel -->
  <div class="tab-panel" id="grade3">
    <div class="cards-grid">
      {grade3Words.map(word => (
        <Flashcard {...word} />
      ))}
    </div>
  </div>

  <!-- Grade 4 Tab Panel -->
  <div class="tab-panel" id="grade4">
    <div class="cards-grid">
      {grade4Words.map(word => (
        <Flashcard {...word} />
      ))}
    </div>
  </div>

  <!-- Grade 5 Tab Panel -->
  <div class="tab-panel" id="grade5">
    <div class="cards-grid">
      {grade5Words.map(word => (
        <Flashcard {...word} />
      ))}
    </div>
  </div>

  <!-- Grade 6 Tab Panel -->
  <div class="tab-panel" id="grade6">
    <div class="cards-grid">
      {grade6Words.map(word => (
        <Flashcard {...word} />
      ))}
    </div>
  </div>
</Layout>

<script>
  // Show active tab panel based on localStorage preference
  const preferredGrade = localStorage.getItem('preferredGrade') || 'grade3';
  const activePanel = document.getElementById(preferredGrade);
  if (activePanel) {
    activePanel.classList.add('active');
  } else {
    document.getElementById('grade3')?.classList.add('active');
  }
</script>

<style>
  .vocab-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .vocab-title {
    font-size: 2.6rem;
    margin-bottom: 8px;
    color: #1a202c;
  }

  .vocab-subtitle {
    color: var(--color-text-muted);
    font-size: 1.15rem;
    font-weight: 600;
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.5;
  }

  /* Panels Grid */
  .tab-panel {
    display: none;
    animation: fadeIn 0.4s ease-out;
  }

  .tab-panel.active {
    display: block;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
    padding-bottom: 40px;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
